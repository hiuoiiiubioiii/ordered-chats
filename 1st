            "The map will store previously seen values and their indices.",
          jennyNarration:
            "We’re carrying a memory box. Every time we see a number, we ask: did I already meet the partner I need?",
          interviewNarration:
            "I’ll do a single left-to-right scan with a hash map storing prior values and indices.",
          state: {
            variables: { target },
            arrays: [
              {
                name: "nums",
                values: nums,
                highlights: []
              }
            ],
            maps: [
              {
                name: "seen",
                entries: {}
              }
            ]
          },
          invariantNote:
            "Before processing any index, the map summarizes the empty processed prefix."
        });

        for (let i = 0; i < nums.length; i++) {
          const value = nums[i];
          const need = target - value;
          const found = Object.prototype.hasOwnProperty.call(seen, String(need));

          steps.push({
            step: step++,
            phase: "lookup",
            title: `Process index ${i}`,
            narration: `Current value is ${value}. We need ${need} to reach target ${target}. Check whether ${need} already exists in the map.`,
            jennyNarration:
              `At index ${i}, we are holding ${value}. Its perfect partner would be ${need}. Let’s look inside the memory box.`,
            interviewNarration:
              `At i = ${i}, I compute need = target - nums[i]. Then I check if that complement is already in the map.`,
            codeLineRefs: [5, 6],
            state: {
              variables: { i, value, need, target },
              arrays: [
                {
                  name: "nums",
                  values: nums,
                  highlights: [{ index: i, kind: "active" }]
                }
              ],
              maps: [
                {
                  name: "seen",
                  entries: { ...seen },
                  queriedKey: String(need),
                  queriedResult: found ? seen[String(need)] : null
                }
              ]
            },
            decisionNote: found
              ? `Complement ${need} found at index ${seen[String(need)]}.`
              : `Complement ${need} not found yet.`,
            invariantNote:
              "Before insertion of current value, the map contains exactly the values from indices 0..i-1."
          });

          if (found) {
            steps.push({
              step: step++,
              phase: "return",
              title: "Return matching indices",
              narration: `The complement ${need} was already seen at index ${seen[String(need)]}. Return [${seen[String(need)]}, ${i}].`,
              jennyNarration:
                `Boom — the partner is already in memory. That means we found the answer immediately.`,
              interviewNarration:
                "Since the complement exists in the processed prefix, I can return the stored index and the current index.",
              codeLineRefs: [7, 8],
              state: {
                variables: {
                  i,
                  value,
                  need,
                  answer: [seen[String(need)], i]
                },
                arrays: [
                  {
                    name: "nums",
                    values: nums,
                    highlights: [
                      { index: seen[String(need)], kind: "success" },
                      { index: i, kind: "success" }
                    ]
                  }
                ],
                maps: [
                  {
                    name: "seen",
                    entries: { ...seen },
                    queriedKey: String(need),
                    queriedResult: seen[String(need)]
                  }
                ]
              },
              invariantNote:
                "The found map entry came from an earlier index, so the same element is not reused."
            });
            break;
          }

          seen[String(value)] = i;

          steps.push({
            step: step++,
            phase: "insert",
            title: `Store value ${value}`,
            narration: `No answer yet, so insert ${value} -> ${i} into the map for future elements.`,
            jennyNarration:
              `No partner yet. Save ${value} with its index so future numbers can find it.`,
            interviewNarration:
              "If the complement is not found, I insert the current value and index into the map.",
            codeLineRefs: [10],
            state: {
              variables: { i, value },
              arrays: [
                {
                  name: "nums",
                  values: nums,
                  highlights: [{ index: i, kind: "inserted" }]
                }
              ],
              maps: [
                {
                  name: "seen",
                  entries: { ...seen },
                  lastInserted: { key: String(value), value: i }
                }
              ]
            },
            memoryDiff: {
              added: [`seen[${value}] = ${i}`]
            },
            invariantNote:
              "After insertion, the map summarizes exactly the processed prefix 0..i."
          });
        }

        return steps;
      }
    }
  },

