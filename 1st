          codePrimary: `class Solution {\npublic:\n    vector<int> twoSum(vector<int>& nums, int target) {\n        unordered_map<int, int> seen;\n        for (int i = 0; i < (int)nums.size(); ++i) {\n            int need = target - nums[i];\n            if (seen.count(need)) {\n                return {seen[need], i};\n            }\n            seen[nums[i]] = i;\n        }\n        return {};\n    }\n};`,
          complexity: { time: "O(n) average", space: "O(n)" }
        }
      },
      traces: {
        bruteForceTrace: {
          generate: (testCase) => {
            const nums = testCase.input.nums; const target = testCase.input.target;
            const steps = []; let step = 1; let comparisons = 0;

            steps.push({ step: step++, phase: "init", title: "Initialize brute-force scan", narration: "We will test every pair (i, j) with i < j until we find a sum equal to the target.", state: { variables: { target, comparisons }, arrays: [{ name: "nums", values: nums, highlights: [] }] }, invariantNote: "No pair has been tested yet." });
            outer: for (let i = 0; i < nums.length; i++) {
              for (let j = i + 1; j < nums.length; j++) {
                comparisons += 1; const currentSum = nums[i] + nums[j]; const found = currentSum === target;
                steps.push({ step: step++, phase: "compare", title: `Test pair (${i}, ${j})`, narration: `Check whether nums[${i}] + nums[${j}] = ${nums[i]} + ${nums[j]} = ${currentSum} matches target ${target}.`, codeLineRefs: [5, 6], state: { variables: { i, j, currentSum, target, comparisons }, arrays: [{ name: "nums", values: nums, highlights: [{ index: i, kind: "active" }, { index: j, kind: found ? "success" : "active" }] }] }, decisionNote: found ? "This pair reaches the target." : "This pair does not reach the target." });
                if (found) {
                  steps.push({ step: step++, phase: "return", title: "Return answer", narration: `The first valid pair found is [${i}, ${j}].`, codeLineRefs: [7], state: { variables: { answer: `[${i}, ${j}]`, comparisons }, arrays: [{ name: "nums", values: nums, highlights: [{ index: i, kind: "success" }, { index: j, kind: "success" }] }] }, invariantNote: "Found a matching pair." });
                  break outer;
                }
              }
            }
            return steps;
          }
        },
        optimizedTrace: {
          generate: (testCase) => {
            const nums = testCase.input.nums; const target = testCase.input.target;
            const steps = []; const seen = {}; let step = 1;

            steps.push({ step: step++, phase: "init", title: "Initialize hash map", narration: "The map will store previously seen values and their indices.", jennyNarration: "We’re carrying a memory box. Every time we see a number, we ask: did I already meet the partner I need?", interviewNarration: "I’ll do a single left-to-right scan with a hash map storing prior values.", codeLineRefs: [4], state: { variables: { target }, arrays: [{ name: "nums", values: nums, highlights: [] }], maps: [{ name: "seen", entries: {} }] }, invariantNote: "Map is currently empty." });
            for (let i = 0; i < nums.length; i++) {
              const value = nums[i]; const need = target - value; const found = Object.prototype.hasOwnProperty.call(seen, String(need));

              steps.push({ step: step++, phase: "lookup", title: `Process index ${i}`, narration: `Current value is ${value}. We need ${need} to reach target ${target}. Check whether ${need} already exists in the map.`, jennyNarration: `At index ${i}, we are holding ${value}. Its perfect partner would be ${need}. Let’s look inside the memory box.`, interviewNarration: `At i = ${i}, I compute need = target - nums[i]. Then I check if that complement is already in the map.`, codeLineRefs: [5, 6, 7], state: { variables: { i, value, need, target }, arrays: [{ name: "nums", values: nums, highlights: [{ index: i, kind: "active" }] }], maps: [{ name: "seen", entries: { ...seen }, queriedKey: String(need), queriedResult: found ? seen[String(need)] : null }] }, decisionNote: found ? `Complement ${need} found at index ${seen[String(need)]}.` : `Complement ${need} not found yet.`, invariantNote: "Map contains exactly the values from indices 0..i-1." });
              if (found) {
                steps.push({ step: step++, phase: "return", title: "Return matching indices", narration: `The complement ${need} was already seen at index ${seen[String(need)]}. Return [${seen[String(need)]}, ${i}].`, jennyNarration: `Boom — the partner is already in memory. That means we found the answer immediately.`, interviewNarration: "Since the complement exists in the processed prefix, I can return the stored index and the current index.", codeLineRefs: [8], state: { variables: { i, value, need, answer: `[${seen[String(need)]}, ${i}]` }, arrays: [{ name: "nums", values: nums, highlights: [{ index: seen[String(need)], kind: "success" }, { index: i, kind: "success" }] }], maps: [{ name: "seen", entries: { ...seen }, queriedKey: String(need), queriedResult: seen[String(need)] }] } });
                break;
              }
              seen[String(value)] = i;
              steps.push({ step: step++, phase: "insert", title: `Store value ${value}`, narration: `No answer yet, so insert ${value} -> ${i} into the map for future elements.`, jennyNarration: `No partner yet. Save ${value} with its index so future numbers can find it.`, interviewNarration: "If the complement is not found, I insert the current value and index into the map.", codeLineRefs: [10], state: { variables: { i, value }, arrays: [{ name: "nums", values: nums, highlights: [{ index: i, kind: "inserted" }] }], maps: [{ name: "seen", entries: { ...seen }, lastInserted: { key: String(value), value: i } }] } });
            }
            return steps;
          }
        }
      }
    };

